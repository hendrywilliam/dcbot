# Discord Bot Configuration
DC_APPLICATION_ID=your_discord_application_id_here
DC_BOT_TOKEN=your_discord_bot_token_here
DC_PUBLIC_KEY=your_discord_public_key_here
DC_OAUTH2_TOKEN=your_discord_oauth2_token_here
DC_GATEWAY_VERSION=10
DC_VOICE_GATEWAY_VERSION=4
DC_HTTP_BASE_URL=https://discord.com/api/v10
DC_GATEWAY_ADDRESS=wss://gateway.discord.gg

# Application Environment
APP_ENV=development

# Logging Configuration
LOG_LEVEL=debug
